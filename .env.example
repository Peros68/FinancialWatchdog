# FinancialWatchdog — environment variables (template)
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).

# --- Market data provider (server-side only) ---
# Finnhub API key used by the backend proxy (/api/stocks/*).
# Without it, stock search/quote/profile/chart endpoints return errors.
# Get a free key at https://finnhub.io/dashboard
FINNHUB_API_KEY=

# --- Database (NOT required yet) ---
# The app currently runs with in-memory storage (no DB needed locally).
# When local PostgreSQL is introduced (decision D1), set the connection string here.
# Example (local Postgres): postgres://user:password@localhost:5432/financialwatchdog
# DATABASE_URL=

# --- Legacy external alert backend (decision D2, optional) ---
# The Alerts page currently reads from this external FastAPI service. It is a
# temporary/legacy dependency to be removed in favor of the local backend.
# Override the base URL here if needed (client-side, VITE_ prefix).
# VITE_LEGACY_ALERT_API_BASE=https://borsa-alert.onrender.com

# --- Runtime ---
# NODE_ENV is auto-detected by the server (dev via tsx, prod via dist bundle).
# Set it explicitly only to override. e.g. NODE_ENV=production
# NODE_ENV=
